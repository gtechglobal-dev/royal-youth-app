export const getAllSpecialDonations = async (req, res) => {
  try {
    const incomes = await Income.find({
      memberId: { $exists: true },
      memberId: { $ne: null }
    }).populate("memberId", "firstname surname").sort({ createdAt: -1 });
    
    const months2026 = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
    
    const specialDonations = incomes.filter(income => {
      const isDuesPayment = income.purpose.includes("2026 Dues") || income.purpose.includes("Dues -");
      return !isDuesPayment;
    });
    
    res.status(200).json(specialDonations);
  } catch (error) {
    console.error("Error getting all special donations:", error);
    res.status(500).json({ error: error.message });
  }
};

export { initializePayment, verifyPayment, handlePaystackWebhook, getDuesIncome, initializeSpecialPayment, verifySpecialPayment, getSpecialPayments };